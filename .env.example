RESTREAM_CHAT_TOKEN=your-token-here
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret
SPOTIFY_REFRESH_TOKEN=your-refresh-token

# 1 = MediaMTX republica a stream pra Twitch quando OBS publicar
# 0 = só preview local no /admin (default — relay desligado)
RELAY_TWITCH=0

# Twitch primary stream key (Creator Dashboard → Settings → Stream)
# Usado pelo MediaMTX pra relay automático: OBS → MediaMTX → Twitch
# Só tem efeito se RELAY_TWITCH=1
TWITCH_STREAM_KEY=
